# Porta do servidor (Express + Socket.io). O client em dev faz proxy para ela.
PORT=4000

# === Spotify (Fase 4) ===
# Crie um app em https://developer.spotify.com/dashboard e cole o Client ID.
# O redirect deve ser loopback (sem HTTPS) para evitar a exigência de HTTPS em IPs de LAN.
SPOTIFY_CLIENT_ID=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4000/spotify/callback
