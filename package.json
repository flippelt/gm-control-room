{
  "name": "gm-control-room",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev -w @gmcr/server",
    "dev:client": "npm run dev -w @gmcr/client",
    "build": "npm run build -w @gmcr/shared && npm run build -w @gmcr/client && npm run build -w @gmcr/server",
    "build:shared": "npm run build -w @gmcr/shared",
    "start": "node server/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "vitest": "^4.1.8"
  }
}
